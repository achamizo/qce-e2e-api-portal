{
  "openapi" : "3.0.1",
  "info" : {
    "title" : "KJB - Custom - CRV",
    "description" : "No description",
    "contact" : { },
    "version" : "1.0.0"
  },
  "servers" : [ {
    "url" : "http://localhost:8042/services/crv_api"
  } ],
  "paths" : {
    "/invoice/{id}" : {
      "get" : {
        "tags" : [ "Invoice", "API", "REST" ],
        "summary" : "GetInvoiceInfo",
        "description" : "Obtener información de una factura específica. Esta API recibe como parámetro el **id** de la factura y devuelve el detalle de la misma.",
        "responses" : {
          "200" : {
            "description" : "Estatus 200 si la factura es encontrada",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Invoice_JSON"
                }
              }
            }
          },
          "404" : {
            "description" : "Invoice Not Found",
            "content" : {
              "application/json" : {
                "schema" : {
                  "type" : "object"
                },
                "example" : "{\n    \"error\": [\n        \"mesage\": \"The invoice 1111111 was not found\"\n  ]\n}"
              }
            }
          }
        }
      },
      "parameters" : [ {
        "name" : "id",
        "in" : "path",
        "required" : true,
        "schema" : {
          "type" : "string"
        }
      } ]
    },
    "/invoice" : {
      "get" : {
        "tags" : [ "Invoice", "API", "REST", "Supplier" ],
        "summary" : "GetSupplierInvoices",
        "parameters" : [ {
          "name" : "supplierId",
          "in" : "query",
          "description" : "Supplier ID",
          "schema" : {
            "type" : "string",
            "description" : "Supplier ID"
          },
          "example" : "1111111"
        }, {
          "name" : "fromDate",
          "in" : "query",
          "description" : "From Date",
          "schema" : {
            "type" : "string",
            "description" : "From Date"
          },
          "example" : "2025-01-01"
        }, {
          "name" : "toDate",
          "in" : "query",
          "description" : "To Date",
          "schema" : {
            "type" : "string",
            "description" : "To Date"
          },
          "example" : "2025-01-31"
        } ],
        "responses" : {
          "200" : {
            "description" : "Status 200",
            "content" : {
              "application/json" : {
                "schema" : {
                  "$ref" : "#/components/schemas/Invoice_JSON"
                },
                "example" : "{\n  \"Invoice\": [\n        {\n            \"supplierId\": 1111111,\n            \"supplierName\": \"Emisor Anonimo_1111111\",\n            \"customerId\": 19999999,\n            \"customerName\": \"Receptor Anonimo_29999999\",\n            \"number\": \"FV6076230706\",\n            \"date\": \"2024-02-10\",\n            \"subTotal\": \"34,874.00\",\n            \"total\": \"41,500.00\"\n        },\n        {\n            \"supplierId\": 2222222,\n            \"supplierName\": \"Emisor Anonimo_2222222\",\n            \"customerId\": 29999999,\n            \"customerName\": \"Receptor Anonimo_29999999\",\n            \"number\": \"FV6076230706\",\n            \"date\": \"2024-02-10\",\n            \"subTotal\": \"34,874.00\",\n            \"total\": \"41,500.00\"\n        },\n        {\n            \"supplierId\": 3333333,\n            \"supplierName\": \"Emisor Anonimo_3333333\",\n            \"customerId\": 39999999,\n            \"customerName\": \"Receptor Anonimo_29999999\",\n            \"number\": \"FV6076230706\",\n            \"date\": \"2024-02-10\",\n            \"subTotal\": \"34,874.00\",\n            \"total\": \"41,500.00\"\n        }\n    ]\n}"
              }
            }
          }
        }
      }
    }
  },
  "components" : {
    "schemas" : {
      "Invoice_JSON" : {
        "type" : "object",
        "description" : "Invoice JSON Structure",
        "properties" : {
          "Invoice" : {
            "type" : "object",
            "description" : "Invoice Information",
            "properties" : {
              "supplierId" : {
                "type" : "number",
                "description" : "Supplier ID",
                "minimum" : 1,
                "maximum" : 15,
                "example" : 1111111
              },
              "supplierName" : {
                "type" : "string",
                "description" : "Supplier Name",
                "minLength" : 1,
                "maxLength" : 50,
                "example" : "Emisor Anonimo_1111111"
              },
              "customerId" : {
                "type" : "number",
                "description" : "Customer ID",
                "minimum" : 1,
                "maximum" : 15,
                "example" : 29999999
              },
              "customerName" : {
                "type" : "string",
                "description" : "Customer Name",
                "minLength" : 1,
                "maxLength" : 50,
                "example" : "Receptor Anonimo_29999999"
              },
              "number" : {
                "type" : "string",
                "description" : "Invoice Number",
                "minLength" : 1,
                "maxLength" : 15,
                "example" : "FV6076230706"
              },
              "date" : {
                "type" : "string",
                "description" : "Invoice Date",
                "minLength" : 10,
                "maxLength" : 10,
                "pattern" : "YYYY-MM-DD",
                "example" : "2024-02-10"
              },
              "subTotal" : {
                "type" : "string",
                "description" : "Invoice Subtotal Amount",
                "example" : "34,874.00"
              },
              "total" : {
                "type" : "string",
                "description" : "Invoice Total Amount",
                "example" : "41,500.00"
              }
            }
          }
        },
        "example" : "{\n  \"Invoice\": {\n    \"supplierId\": 1111111,\n    \"supplierName\": \"Emisor Anonimo_1111111\",\n    \"customerId\": 29999999,\n    \"customerName\": \"Receptor Anonimo_29999999\",\n    \"number\": \"FV6076230706\",\n    \"date\": \"2024-02-10\",\n    \"subTotal\": \"34,874.00\",\n    \"total\": \"41,500.00\"\n  }\n}"
      }
    }
  }
}