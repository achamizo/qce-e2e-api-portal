{
  "swagger" : "2.0",
  "info" : {
    "description" : "This is the offical API for trusted Customer data at our organization.",
    "version" : "1.0.0",
    "title" : "KJB - Customer API",
    "contact" : { }
  },
  "host" : "localhost:8042",
  "basePath" : "/services/customer-api",
  "schemes" : [ "http" ],
  "paths" : {
    "/customer/{id}/" : {
      "get" : {
        "summary" : "Get by Customer ID",
        "description" : "Get Customer using the Customer ID",
        "produces" : [ "application/json" ],
        "parameters" : [ ],
        "responses" : {
          "200" : {
            "description" : "Status 200",
            "schema" : {
              "$ref" : "#/definitions/Customer_JSON"
            }
          }
        }
      },
      "delete" : {
        "summary" : "Delete Customer",
        "description" : "Delete the Customer by ID",
        "parameters" : [ ],
        "responses" : {
          "202" : {
            "description" : "Status 202"
          }
        }
      },
      "parameters" : [ {
        "name" : "id",
        "in" : "path",
        "required" : true,
        "type" : "string"
      } ]
    },
    "/customer/" : {
      "get" : {
        "tags" : [ "Qlik", "Demo" ],
        "summary" : "Get Customers",
        "description" : "Operacion que permite obtener la lista de clientes",
        "produces" : [ "application/json" ],
        "parameters" : [ {
          "name" : "lastName",
          "in" : "query",
          "required" : false,
          "type" : "string",
          "description" : "Customer Last Name",
          "maxLength" : 50,
          "x-example" : "Jones"
        }, {
          "name" : "entryTerm",
          "in" : "query",
          "required" : false,
          "type" : "string",
          "description" : "Customer Entry Term",
          "minLength" : 6,
          "maxLength" : 6,
          "x-example" : "201801"
        }, {
          "name" : "applicantStatus",
          "in" : "query",
          "required" : false,
          "type" : "string",
          "description" : "Customer Applicant Status",
          "enum" : [ "accepted", "denied", "withdraw", "enrolled" ]
        }, {
          "name" : "firstName",
          "in" : "query",
          "required" : false,
          "type" : "string",
          "description" : "Customer First Name",
          "maxLength" : 50,
          "x-example" : "John"
        } ],
        "responses" : {
          "200" : {
            "description" : "Status 200",
            "schema" : {
              "type" : "array",
              "items" : {
                "$ref" : "#/definitions/Customer_JSON"
              }
            },
            "examples" : {
              "application/json" : "{  \n   \"customer\":[  \n      {  \n         \"customerId\":145003,\n         \"firstName\":\"Benjamin\",\n         \"middleName\":\"Woodrow\",\n         \"lastName\":\"Fillmore\",\n         \"applicantStatus\":\"withdraw\",\n         \"entryTerm\":201702,\n         \"address\":\"539 Cleveland Ave.\",\n         \"city\":\"Helena\",\n         \"state\":\"Mississippi\",\n         \"zip\":3657\n      },\n      {  \n         \"customerId\":145013,\n         \"firstName\":\"Andrew\",\n         \"middleName\":\"Warren\",\n         \"lastName\":\"Fillmore\",\n         \"applicantStatus\":\"accepted\",\n         \"entryTerm\":201701,\n         \"address\":\"1229 Bailard Avenue\",\n         \"city\":\"Trenton\",\n         \"state\":\"South Carolina\",\n         \"zip\":63959\n      },\n      {  \n         \"customerId\":145091,\n         \"firstName\":\"Millard\",\n         \"middleName\":\"Richard\",\n         \"lastName\":\"Fillmore\",\n         \"applicantStatus\":\"enrolled\",\n         \"entryTerm\":201701,\n         \"address\":\"1090 Carpinteria North\",\n         \"city\":\"Providence\",\n         \"state\":\"Maine\",\n         \"zip\":57472\n      }\n   ]\n}"
            }
          }
        }
      },
      "post" : {
        "summary" : "Add a new Customer",
        "consumes" : [ "application/json" ],
        "parameters" : [ {
          "name" : "body",
          "in" : "body",
          "required" : true,
          "schema" : {
            "$ref" : "#/definitions/Customer_JSON"
          },
          "x-examples" : {
            "application/json" : "{\n  \"customer\": {\n    \"customerId\": 55555,\n    \"firstName\": \"Andrew\",\n    \"middleName\": \"Franklin\",\n    \"lastName\": \"Quincy\",\n    \"applicantStatus\": \"accepted\",\n    \"entryTerm\": 201702,\n    \"address\": \"1793 East Main Street\",\n    \"city\": \"Columbia\",\n    \"state\": \"Hawaii\",\n    \"zip\": 62433\n  }\n}"
          }
        } ],
        "responses" : {
          "200" : {
            "description" : "Status 200"
          }
        }
      }
    }
  },
  "definitions" : {
    "applicantStatus" : {
      "type" : "string",
      "description" : "The Student Applicant Status",
      "enum" : [ "accepted", "denied", "withdraw", "enrolled" ]
    },
    "Customer_JSON" : {
      "type" : "object",
      "properties" : {
        "Customer" : {
          "type" : "object",
          "properties" : {
            "zip" : {
              "type" : "number",
              "description" : "Postal Code"
            },
            "city" : {
              "type" : "string",
              "maxLength" : 50
            },
            "state" : {
              "type" : "string",
              "description" : "State, Province, etc.",
              "minLength" : 2,
              "maxLength" : 2
            },
            "address" : {
              "type" : "string",
              "description" : "Street address"
            },
            "lastName" : {
              "type" : "string",
              "maxLength" : 50
            },
            "entryTerm" : {
              "type" : "number",
              "example" : 201701
            },
            "firstName" : {
              "type" : "string",
              "maxLength" : 50
            },
            "studentId" : {
              "type" : "number",
              "example" : 145001
            },
            "middleName" : {
              "type" : "string",
              "maxLength" : 50
            },
            "applicantStatus" : {
              "$ref" : "#/definitions/applicantStatus"
            }
          }
        }
      },
      "description" : "Customer JSON Structure",
      "example" : "{\n  \"customer\": {\n    \"customerId\": 145025,\n    \"firstName\": \"Andrew\",\n    \"middleName\": \"Franklin\",\n    \"lastName\": \"Quincy\",\n    \"applicantStatus\": \"accepted\",\n    \"entryTerm\": 201702,\n    \"address\": \"1793 East Main Street\",\n    \"city\": \"Columbia\",\n    \"state\": \"Hawaii\",\n    \"zip\": 62433\n  }\n}"
    }
  }
}